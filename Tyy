SELECT
    relname AS table_name,
    n_live_tup AS row_count
FROM pg_stat_user_tables
WHERE schemaname = 'public'
ORDER BY relname;


SELECT
    'SELECT ''' || table_name || ''' AS table_name, COUNT(*) FROM public.' || table_name
FROM information_schema.tables
WHERE table_schema = 'public'
AND table_type = 'BASE TABLE';


SELECT 'table1' AS table_name, COUNT(*) FROM public.table1
UNION ALL
SELECT 'table2', COUNT(*) FROM public.table2
UNION ALL
SELECT 'table3', COUNT(*) FROM public.table3;



DO $$
DECLARE
    r RECORD;
BEGIN
    FOR r IN
        SELECT table_name
        FROM information_schema.tables
        WHERE table_schema = 'public'
        AND table_type = 'BASE TABLE'
    LOOP
        EXECUTE format(
            'SELECT ''%s'' AS table_name, COUNT(*) AS row_count FROM public.%I',
            r.table_name,
            r.table_name
        );
    END LOOP;
END $$;
