      "id": "http-003",
      "name": "Claude AI Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2220, 300],
      "notes": "Uses Anthropic Claude API. Replace with OpenAI if preferred."
    },
    {
      "parameters": {
        "jsCode": "// Parse AI response and format the final OSS report\nconst response = $input.item.json;\n\nlet report;\ntry {\n  // Extract text from Claude's response format\n  const text = response.content[0].text;\n  // Strip any accidental markdown fences\n  const clean = text.replace(/```json|```/g, '').trim();\n  report = JSON.parse(clean);\n} catch (e) {\n  report = { error: 'Failed to parse AI response', raw: JSON.stringify(response) };\n}\n\n// Build a human-readable markdown summary\nlet markdown = `# OSS Tool Scan Report\\n`;\nmarkdown += `**Repository:** ${report.repository || 'Unknown'}\\n`;\nmarkdown += `**Scan Date:** ${report.scan_date || new Date().toISOString()}\\n\\n`;\nmarkdown += `## Summary\\n${report.summary || ''}\\n\\n`;\n\nif (report.tools && report.tools.length > 0) {\n  // Group by category\n  const byCategory = {};\n  for (const tool of report.tools) {\n    const cat = tool.category || 'Other';\n    if (!byCategory[cat]) byCategory[cat] = [];\n    byCategory[cat].push(tool);\n  }\n\n  markdown += `## Discovered Tools (${report.tools.length} total)\\n\\n`;\n  for (const [cat, tools] of Object.entries(byCategory)) {\n    markdown += `### ${cat}\\n`;\n    for (const t of tools) {\n      const ver = t.version ? ` v${t.version}` : '';\n      const lic = t.license_hint ? ` [${t.license_hint}]` : '';\n      markdown += `- **${t.name}**${ver}${lic} — \\`${t.source_file}\\`\\n`;\n    }\n    markdown += '\\n';\n  }\n}\n\nreturn [{\n  json: {\n    report,\n    markdown_summary: markdown,\n    tool_count: report.tools ? report.tools.length : 0\n  }\n}];\n"
      },
