    {
      "parameters": {
        "jsCode": "// Decode base64 file content from GitHub API\nconst item = $input.item.json;\n\nlet decodedContent = '';\ntry {\n  // GitHub returns content as base64 with newlines\n  const raw = (item.content || '').replace(/\\n/g, '');\n  decodedContent = Buffer.from(raw, 'base64').toString('utf8');\n} catch (e) {\n  decodedContent = '[Could not decode content]';\n}\n\nreturn [{\n  json: {\n    filename: item.name,\n    path: item.path,\n    content: decodedContent\n  }\n}];\n"
      },
      "id": "code-002",
      "name": "Decode Base64 Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "destinationFieldName": "files",
        "options": {}
      },
      "id": "agg-001",
      "name": "Aggregate All Files",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "jsCode": "// Build a structured prompt for Claude/OpenAI\nconst files = $input.item.json.files || [];\n\nlet fileContext = '';\nfor (const f of files) {\n  fileContext += `\\n\\n--- FILE: ${f.path} ---\\n${f.content}`;\n}\n\nconst prompt = `You are an expert software auditor specializing in open source software (OSS) compliance and dependency analysis.\n\nBelow are the contents of files from a GitHub repository (an Ansible infrastructure role).\n\nYour task:\n1. Identify ALL open source tools, libraries, packages, roles, and dependencies referenced in these files.\n2. For each one, extract: name, version (if present), category (e.g. Python lib, Ansible Galaxy role, Docker base image, OS package, CLI tool, etc.), and which file it was found in.\n3. Return your response ONLY as valid JSON — no explanation, no markdown fences.\n\nJSON format:\n{\n  \"repository\": \"ansible-role-testimage\",\n  \"scan_date\": \"${new Date().toISOString()}\",\n  \"tools\": [\n    {\n      \"name\": \"example-package\",\n      \"version\": \"1.2.3\",\n      \"category\": \"Python Library\",\n      \"source_file\": \"requirements.txt\",\n      \"license_hint\": \"MIT (if known)\"\n    }\n  ],\n  \"summary\": \"Brief summary of what this repo does and its OSS footprint.\"\n}\n\nFiles to analyze:${fileContext}`;\n\nreturn [{ json: { prompt, files_analyzed: files.length } }];\n"
      },
      "id": "code-003",
      "name": "Build AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 300]
    },
