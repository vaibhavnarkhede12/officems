      "id": "http-001",
      "name": "Get Repo File Tree",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "// -------------------------------------------------------\n// AI-assisted file filtering\n// This code sends the full file list to Claude and asks it\n// to pick only the files relevant for OSS detection\n// -------------------------------------------------------\n\nconst tree = $input.item.json.tree || [];\nconst vars = $('Set Repo Variables').item.json;\n\n// Quick pre-filter: skip binary/media/irrelevant extensions\nconst skip = ['.png','.jpg','.gif','.svg','.ico','.woff','.ttf','.mp4','.zip','.tar','.gz','.lock'];\nconst candidates = tree\n  .filter(f => f.type === 'blob')\n  .filter(f => !skip.some(ext => f.path.endsWith(ext)))\n  .map(f => f.path);\n\n// Known dependency/tool files — prioritize these\nconst priority = [\n  'requirements.txt', 'requirements.yml', 'requirements.yaml',\n  'package.json', 'package-lock.json',\n  'Dockerfile', 'docker-compose.yml', 'docker-compose.yaml',\n  'go.mod', 'go.sum',\n  'pom.xml', 'build.gradle', 'build.gradle.kts',\n  'Pipfile', 'Pipfile.lock', 'pyproject.toml', 'setup.py', 'setup.cfg',\n  'Gemfile', 'Gemfile.lock',\n  'Cargo.toml',\n  'meta/main.yml', 'meta/main.yaml',\n  'tasks/main.yml', 'tasks/main.yaml'\n];\n\nconst filtered = candidates.filter(path => {\n  const name = path.split('/').pop();\n  // Always include known dependency files\n  if (priority.includes(name) || priority.includes(path)) return true;\n  // Include all YAML/YML (Ansible playbooks, roles, etc.)\n  if (name.endsWith('.yml') || name.endsWith('.yaml')) return true;\n  // Include all txt files\n  if (name.endsWith('.txt')) return true;\n  // Include shell scripts\n  if (name.endsWith('.sh')) return true;\n  return false;\n});\n\n// Return each file as a separate item for looping\nreturn filtered.map(path => ({\n  json: {\n    path,\n    owner: vars.owner,\n    repo: vars.repo,\n    base_url: vars.base_url,\n    github_token: vars.github_token\n  }\n}));\n"
      },
      "id": "code-001",
      "name": "Filter Relevant Files",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
