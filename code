const input = $input.first().json.chatInput;

// Extract from full URL like https://alm-github.systems.uk.citi/OWNER/REPO
const match = input.match(/alm-github\.systems\.uk\.citi\/([^\/]+)\/([^\/\s]+)/);

const owner = match ? match[1] : '';
const repo  = match ? match[2].replace(/\.git$/, '') : '';

return [{
  json: {
    owner,
    repo,
    branch: 'main',   // change to 'master' if needed
    chatInput: input
  }
}];